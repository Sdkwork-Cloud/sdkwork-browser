      "auth": {
        "mode": "dual-token",
        "required": true
      },
      "ownership": {
        "owner": "sdkwork-browser",
        "apiAuthority": "sdkwork-browser-backend-api",
        "sdkFamily": "sdkwork-browser-backend-sdk",
