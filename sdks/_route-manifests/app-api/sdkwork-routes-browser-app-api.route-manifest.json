{
  "schemaVersion": 1,
  "kind": "sdkwork.route.manifest",
  "packageName": "sdkwork-routes-browser-app-api",
  "surface": "app-api",
  "owner": "sdkwork-browser",
  "domain": "platform",
  "capability": "browser",
  "apiAuthority": "sdkwork-browser-app-api",
  "sdkFamily": "sdkwork-browser-app-sdk",
  "prefix": "/app/v3/api",
  "source": {
