      "tags": [
        "browser"
      ],
      "requestContext": "WebRequestContext",
      "apiSurface": "app-api",
      "auth": {
        "mode": "dual-token",
        "required": true
      },
      "ownership": {
        "owner": "sdkwork-browser",
        "apiAuthority": "sdkwork-browser-app-api",
        "sdkFamily": "sdkwork-browser-app-sdk",
        "sourceRouteCrate": "sdkwork-routes-browser-app-api"
