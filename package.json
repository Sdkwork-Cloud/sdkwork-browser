{
  "name": "@sdkwork/browser-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "stop": "pnpm exec sdkwork-app stop",
    "dev": "pnpm dev:standalone",
    "dev:browser": "pnpm dev:browser:postgres:standalone",
    "dev:desktop": "pnpm dev:desktop:postgres:standalone",
    "dev:server": "pnpm exec sdkwork-app dev --runtime-target server --deployment-profile standalone",
    "gateway:run": "cargo run -p sdkwork-browser-standalone-gateway",
    "build": "pnpm exec sdkwork-app build",
    "build:desktop": "pnpm --filter sdkwork-browser-pc build:desktop",
    "test": "pnpm exec sdkwork-app test",
    "test:contracts": "vitest run apps/sdkwork-browser-common/packages/sdkwork-browser-contracts/tests/browserContracts.test.ts",
    "test:pc-react": "vitest run apps/sdkwork-browser-pc/packages/sdkwork-browser-pc-browser/tests/browser.test.ts",
    "test:pc-browser": "vitest run apps/sdkwork-browser-pc/packages/sdkwork-browser-pc-browser/tests/browser.test.ts",
    "test:h5-react": "vitest run apps/sdkwork-browser-h5/packages/sdkwork-browser-h5-react/tests/browser.test.ts",
    "test:governance": "node scripts/browser-governance.test.mjs",
    "typecheck": "tsc --noEmit",
    "check": "pnpm exec sdkwork-app check",
    "verify": "pnpm exec sdkwork-app verify",
    "clean": "pnpm exec sdkwork-app clean",
    "build:component-specs": "node scripts/generate-component-specs.mjs",
    "api:materialize": "node sdks/materialize-browser-v3-openapi-boundaries.mjs",
    "api:materialize:check": "node sdks/materialize-browser-v3-openapi-boundaries.mjs",
    "api:check": "pnpm run api:materialize:check",
    "sdk:generate": "node sdks/generate-browser-sdks.mjs",
    "sdk:generate:app": "node sdks/sdkwork-browser-app-sdk/bin/generate-sdk.mjs",
    "sdk:generate:backend": "node sdks/sdkwork-browser-backend-sdk/bin/generate-sdk.mjs",
    "sdk:generate:check": "node sdks/generate-browser-sdks.mjs",
    "sdk:build": "node scripts/check-browser-sdks.mjs",
    "sdk:check": "node scripts/check-browser-sdks.mjs",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_browser_baseline.sql --module-id browser --owner browser-platform --prefixes browser_ --engines sqlite,postgres",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "test:contract:database": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "api:assembly:materialize": "node ../sdkwork-specs/tools/materialize-api-assembly.mjs --root .",
    "api:assembly:validate": "node ../sdkwork-specs/tools/validate-api-assembly.mjs --root .",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root .",
    "_sdkwork:build": "pnpm --filter sdkwork-browser-pc build",
    "_sdkwork:test": "vitest run",
    "_sdkwork:check": "pnpm run check:app-composition && pnpm run sdk:build && pnpm typecheck && cargo check --workspace",
    "_sdkwork:verify": "pnpm check && pnpm test && pnpm run test:governance && pnpm run sdk:check && cargo test --workspace && pnpm run check:app-composition",
    "_sdkwork:clean": "node scripts/clean.mjs",
    "dev:standalone": "pnpm exec sdkwork-app dev --deployment-profile standalone",
    "dev:cloud": "pnpm exec sdkwork-app dev --deployment-profile cloud",
    "dev:browser:postgres:standalone": "pnpm exec sdkwork-app dev --runtime-target browser --deployment-profile standalone",
    "dev:desktop:postgres:standalone": "pnpm exec sdkwork-app dev --runtime-target desktop --deployment-profile standalone"
  },
  "devDependencies": {
    "@sdkwork/sdk-common": "workspace:*",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "@sdkwork/app-topology": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20.0.0",
    "react-dom": ">=18.2.0 <20.0.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
