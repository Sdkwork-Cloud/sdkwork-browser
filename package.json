{
  "name": "@sdkwork/browser-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --filter sdkwork-browser-pc dev",
    "dev:browser": "pnpm --filter sdkwork-browser-pc dev",
    "dev:desktop": "pnpm --filter sdkwork-browser-pc dev:desktop",
    "dev:gateway": "cargo run -p sdkwork-browser-app-server",
    "build": "pnpm --filter sdkwork-browser-pc build",
    "build:desktop": "pnpm --filter sdkwork-browser-pc build:desktop",
    "test": "vitest run",
    "test:contracts": "vitest run packages/common/browser/sdkwork-browser-contracts/tests/browserContracts.test.ts",
    "test:pc-react": "vitest run apps/sdkwork-browser-pc/packages/sdkwork-browser-pc-react/tests/browser.test.ts",
    "test:h5-react": "vitest run apps/sdkwork-browser-h5/packages/sdkwork-browser-h5-react/tests/browser.test.ts",
    "test:governance": "node scripts/browser-governance.test.mjs",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run sdk:build && pnpm typecheck && cargo check --workspace",
    "verify": "pnpm check && pnpm test && pnpm run test:governance && pnpm run sdk:check && cargo test --workspace",
    "clean": "node scripts/clean.mjs",
    "specs:generate": "node scripts/generate-component-specs.mjs",
    "api:materialize": "node sdks/materialize-browser-v3-openapi-boundaries.mjs",
    "api:materialize:check": "node sdks/materialize-browser-v3-openapi-boundaries.mjs",
    "api:check": "pnpm run api:materialize:check",
    "sdk:generate": "node sdks/generate-browser-sdks.mjs",
    "sdk:generate:app": "node sdks/sdkwork-browser-app-sdk/bin/generate-sdk.mjs",
    "sdk:generate:backend": "node sdks/sdkwork-browser-backend-sdk/bin/generate-sdk.mjs",
    "sdk:generate:check": "node sdks/generate-browser-sdks.mjs",
    "sdk:build": "node scripts/check-browser-sdks.mjs",
    "sdk:check": "node scripts/check-browser-sdks.mjs",
    "db:plan": "cargo test -p sdkwork-browser-storage-sqlx-rust browser_storage_standard -- --nocapture",
    "db:validate": "cargo test -p sdkwork-browser-storage-sqlx-rust"
  },
  "devDependencies": {
    "@sdkwork/sdk-common": "workspace:*",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20.0.0",
    "react-dom": ">=18.2.0 <20.0.0"
  }
}
